<div class="article">
    <div>
        <h1><%= page.title %></h1>
    </div>
    <div class="info">
        <span class="date">
            <span class="icon">
                <i class="fa-solid fa-calendar fa-fw"></i>
            </span>
            <%= date(page.date, "YYYY/M/D") %>
        </span>
        <% if (page.categories && page.categories.data.length !== 0) { %>
        <span class="category">
            <a href="<%- url_for(page.categories.data[0].path) %>">
                <span class="icon">
                    <i class="fa-solid fa-bookmark fa-fw"></i>
                </span>
                <%= page.categories.data[0].name %>
            </a>
        </span>
        <% } %>
        <% if (page.tags && page.tags.data.length !== 0) { %>
        <span class="tags">
            <span class="icon">
                <i class="fa-solid fa-tags fa-fw"></i>
            </span>
            <% let prev; %>
            <% page.tags.data.forEach((tag) => { %>
            <span class="tag">
                <%
                    const colors = theme.colors.filter((color) => color !== prev);
                    let id = Math.floor(Math.random() * colors.length);
                    prev = colors[id];
                %>
                <a href="<%- url_for(tag.path) %>" style="color: <%- colors[id] %>">
                    <%= tag.name %>
                </a>
            </span>
            <% }); %>
        </span>
        <% } %>
    </div>
    <% if (theme.crypto.enable && typeof page.secret !== "undefined") { %>
    <% const CryptoJS = getCryptoJS(); %>
    <input
        id="crypto"
        :class="['input', cryptoStatus]"
        :disabled="cryptoStatus === 'success'"
        ref="crypto"
        placeholder="文章被加密，请输入密码"
        data-encrypted="<%- CryptoJS.AES.encrypt(page.content, page.secret).toString() %>"
        data-shasum="<%- CryptoJS.SHA256(page.content).toString() %>"
        v-model="crypto"
    />
    <transition name="fade">
        <div class="content" ref="content" v-show="cryptoStatus === 'success'"></div>
    </transition>
    <% } else { %>
    <div class="content" v-pre>
        <%- page.content %>
    </div>
    <% } %>
    <% if (page.comments) { %>
    <div id="article-comment-wall" class="article-comment-wall" data-comment-wall>
        <div class="section-title">
            <i class="fa-solid fa-comments"></i> 评论
        </div>
        <div class="msg-input-area">
            <input type="text" data-comment-nickname placeholder="你的昵称" maxlength="20">
            <textarea data-comment-content placeholder="写下你想说的话..." maxlength="500"></textarea>
            <button class="msg-submit-btn" data-comment-submit>发布评论</button>
        </div>
        <ul class="msg-list" data-comment-list></ul>
    </div>
    <% if (theme.waline.enable) { %>
    <div id="comment">
        <div id="waline-container"></div>
    </div>
    <% } %>
    <% if (theme.twikoo.enable) { %>
    <div id="comment">
        <div id="twikoo-container"></div>
    </div>
    <% } %>
    <% } %>
    <%
        const articleSourcePath = page.source
            ? (String(page.source).startsWith("source/") ? String(page.source) : "source/" + String(page.source))
            : "";
        const articleTagText = page.tags && page.tags.data
            ? page.tags.data.map((tag) => tag.name).join(",")
            : "";
    %>
    <div class="article-admin-panel"
        data-article-admin
        data-source-path="<%- encodeURIComponent(articleSourcePath) %>"
        data-current-title="<%- encodeURIComponent(page.title || "") %>"
        data-current-description="<%- encodeURIComponent(page.description || "") %>"
        data-current-tags="<%- encodeURIComponent(articleTagText) %>">
        <button class="admin-toggle-btn article-admin-toggle" type="button">
            <i class="fa-solid fa-lock"></i> 管理员
        </button>
        <div class="admin-login article-admin-login" style="display:none;">
            <input class="article-admin-pwd" type="password" placeholder="输入管理员密码">
            <button class="admin-login-btn article-admin-login-btn" type="button">验证</button>
        </div>
        <div class="article-admin-form" style="display:none;">
            <div class="article-admin-status" data-type="info">管理员模式已开启。</div>
            <h3><i class="fa-solid fa-pen-to-square"></i> 编辑这篇文章</h3>
            <input class="article-edit-title" type="text" placeholder="文章标题">
            <textarea class="article-edit-desc" placeholder="文章简介"></textarea>
            <input class="article-edit-tags" type="text" placeholder="标签，逗号分隔，如 AI,Notes,Workflow">
            <button class="admin-push-btn article-admin-save" type="button">保存文章信息</button>
        </div>
    </div>
</div>
